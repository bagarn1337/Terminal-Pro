{
  "name": "terminal-pro",
  "version": "1.0.0",
  "description": "Terminal Pro - Stock Market Terminal",
  "main": "electron-bridge.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.yourname.terminalpro",
    "productName": "Terminal Pro",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "dist/main.exe",
        "to": "."
      }
    ],
    "files": [
      "**/*",
      "!node_modules/**/*",
      "dist/main.exe"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
